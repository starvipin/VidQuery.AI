# Normalize text files for Linux/Hugging Face builds.
* text=auto eol=lf

# Windows scripts should keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Common source/config files.
*.py text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.pdf binary
*.sqlite binary
*.db binary

# Large generated/model artifacts.
*.joblib filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
